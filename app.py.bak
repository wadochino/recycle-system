def read_csv(file, fieldnames):
    if not os.path.exists(file):
        return []

    with open(file, newline="", encoding="utf-8-sig") as f:
        return list(csv.DictReader(f))

headers = [
    "日付", "取引先", "樹脂", "色", "形状", "荷姿",
    "在庫単位ID", "親ID", "重量kg", "保管場所", "状態", "備考"
]

receipt_headers = [
