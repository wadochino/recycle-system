# ==========================
elif menu == "QR繧ｳ繝ｼ繝臥函謌・:

    st.header("QR繧ｳ繝ｼ繝臥函謌・)

    st.subheader("蝨ｨ蠎ｫ蜊倅ｽ阪・QR繧ｳ繝ｼ繝臥函謌・)

    # 蝨ｨ蠎ｫ荳隕ｧ縺九ｉ驕ｸ謚・
    inventory_rows = get_inventory_rows()

    if inventory_rows:
        unit_ids = [row["蝨ｨ蠎ｫ蜊倅ｽ巧D"] for row in inventory_rows]

        selected_unit_id = st.selectbox("蝨ｨ蠎ｫ蜊倅ｽ巧D繧帝∈謚・, unit_ids)

        if st.button("QR繧ｳ繝ｼ繝臥函謌・):
            try:
                # QR繧ｳ繝ｼ繝峨ｒ逕滓・
                qrcode_data = QRCodeService.generate_qrcode(selected_unit_id)

                # QR繧ｳ繝ｼ繝画ュ蝣ｱ繧剃ｿ晏ｭ・
                result = QRCodeService.save_qrcode_map(
                    selected_unit_id,
                    qrcode_data,
                    qrcode_url=""
                )

                if result['success']:
                    st.success(result['message'])

                    # QR繧ｳ繝ｼ繝峨ｒ陦ｨ遉ｺ
                    st.subheader("逕滓・縺輔ｌ縺櫺R繧ｳ繝ｼ繝・)

                    # HTML縺ｧ陦ｨ遉ｺ
                    html_img = QRCodeService.get_qrcode_html(selected_unit_id, size="300px")
                    st.markdown(html_img, unsafe_allow_html=True)

                    # 繝繧ｦ繝ｳ繝ｭ繝ｼ繝峨・繧ｿ繝ｳ
                    qrcode_info = QRCodeService.get_qrcode(selected_unit_id)

                    if qrcode_info:
                        import base64
                        import io
                        from PIL import Image

                        # Base64繧偵ョ繧ｳ繝ｼ繝峨＠縺ｦPNG蛹・
                        qrcode_bytes = base64.b64decode(qrcode_info['qrcode_data'])

                        st.download_button(
                            label="QR繧ｳ繝ｼ繝峨ｒ繝繧ｦ繝ｳ繝ｭ繝ｼ繝・,
                            data=qrcode_bytes,
                            file_name=f"qrcode_{selected_unit_id}.png",
                            mime="image/png"
                        )

                    # 逶｣譟ｻ繝ｭ繧ｰ繧定ｨ倬鹸
                    AuditLogService.log_action(
                        username=st.session_state.username,
                        action="GENERATE_QRCODE",
                        table_name="qrcode_map",
                        record_id=selected_unit_id,
                        detail=f"QR繧ｳ繝ｼ繝峨ｒ逕滓・縺励∪縺励◆・嘴selected_unit_id}"
                    )

                else:
                    st.error(result['message'])

            except Exception as e:
                st.error(f"繧ｨ繝ｩ繝ｼ・嘴str(e)}")

                # 繧ｨ繝ｩ繝ｼ繝ｭ繧ｰ繧定ｨ倬鹸
                AuditLogService.log_error(
                    username=st.session_state.username,
                    action="GENERATE_QRCODE",
                    error_message=str(e)
                )

    else:
        st.info("蝨ｨ蠎ｫ縺後≠繧翫∪縺帙ｓ縲・)

# ==========================
# 繝ｦ繝ｼ繧ｶ繝ｼ邂｡逅・ｼ・hase 5・・
# ==========================
elif menu == "繝ｦ繝ｼ繧ｶ繝ｼ邂｡逅・:

    st.header("繝ｦ繝ｼ繧ｶ繝ｼ邂｡逅・)

    tab1, tab2 = st.tabs(["繝ｦ繝ｼ繧ｶ繝ｼ菴懈・", "繝ｭ繝ｼ繝ｫ邂｡逅・])

    with tab1:
        st.subheader("譁ｰ隕上Θ繝ｼ繧ｶ繝ｼ菴懈・")

        new_username = st.text_input("繝ｦ繝ｼ繧ｶ繝ｼ蜷・, key="admin_new_user")
        new_password = st.text_input("繝代せ繝ｯ繝ｼ繝・, type="password", key="admin_new_pass")
        new_full_name = st.text_input("繝輔Ν繝阪・繝", key="admin_full_name")
        new_email = st.text_input("繝｡繝ｼ繝ｫ繧｢繝峨Ξ繧ｹ", key="admin_email")

        if st.button("繝ｦ繝ｼ繧ｶ繝ｼ菴懈・", key="admin_create_user"):
            if not new_username:
                st.error("繝ｦ繝ｼ繧ｶ繝ｼ蜷阪ｒ蜈･蜉帙＠縺ｦ縺上□縺輔＞")
            elif len(new_password) < 6:
                st.error("繝代せ繝ｯ繝ｼ繝峨・6譁・ｭ嶺ｻ･荳翫〒縺・)
            else:
                result = AuthService.register_user(
                    new_username,
                    new_password,
                    new_full_name,
                    new_email
                )

                if result['success']:
                    st.success(result['message'])

                    # 逶｣譟ｻ繝ｭ繧ｰ繧定ｨ倬鹸
                    AuditLogService.log_action(
                        username=st.session_state.username,
                        action="CREATE_USER",
                        table_name="users",
                        record_id=new_username,
                        detail=f"繝ｦ繝ｼ繧ｶ繝ｼ繧剃ｽ懈・縺励∪縺励◆・嘴new_username}"
                    )

                else:
                    st.error(result['message'])

    with tab2:
        st.subheader("繝ｭ繝ｼ繝ｫ蜑ｲ繧雁ｽ薙※")

        # 繝ｦ繝ｼ繧ｶ繝ｼ繝ｪ繧ｹ繝医ｒ蜿門ｾ暦ｼ育ｰ｡譏灘ｮ溯｣・ｼ咼B縺九ｉ逶ｴ謗･蜿門ｾ暦ｼ・
        from db import get_conn

        with get_conn() as conn:
            conn.row_factory = lambda c, r: dict(zip([col[0] for col in c.description], r))
            cur = conn.cursor()

            cur.execute("SELECT username, full_name FROM users WHERE is_active = 1")
            users = cur.fetchall()

        if users:
            user_options = {u['full_name']: u['username'] for u in users}

            selected_user = st.selectbox("繝ｦ繝ｼ繧ｶ繝ｼ繧帝∈謚・, list(user_options.keys()))
            selected_username = user_options[selected_user]

            roles = ["蜿怜叙", "讀懈渊", "蜉蟾･", "蜃ｺ闕ｷ", "邂｡逅・, "admin"]

            selected_role = st.selectbox("繝ｭ繝ｼ繝ｫ繧帝∈謚・, roles)

            if st.button("繝ｭ繝ｼ繝ｫ蜑ｲ繧雁ｽ薙※"):
                result = AuthService.assign_role(selected_username, selected_role)

                if result['success']:
                    st.success(result['message'])

                    # 逶｣譟ｻ繝ｭ繧ｰ繧定ｨ倬鹸
                    AuditLogService.log_action(
                        username=st.session_state.username,
                        action="ASSIGN_ROLE",
                        table_name="user_roles",
                        record_id=selected_username,
                        detail=f"繝ｭ繝ｼ繝ｫ繧貞牡繧雁ｽ薙※縺ｾ縺励◆・嘴selected_username} = {selected_role}"
                    )

                else:
                    st.error(result['message'])

            # 迴ｾ蝨ｨ縺ｮ繝ｭ繝ｼ繝ｫ陦ｨ遉ｺ
            st.subheader(f"{selected_user} 縺ｮ繝ｭ繝ｼ繝ｫ")

            current_roles = AuthService.get_user_roles(selected_username)

            if current_roles:
                st.write(", ".join(current_roles))
            else:
                st.info("繝ｭ繝ｼ繝ｫ縺悟牡繧雁ｽ薙※繧峨ｌ縺ｦ縺・∪縺帙ｓ")

        else:
            st.info("繝ｦ繝ｼ繧ｶ繝ｼ縺後≠繧翫∪縺帙ｓ縲・)

# ==========================
# 逶｣譟ｻ繝ｭ繧ｰ・・hase 5・・
# ==========================
elif menu == "逶｣譟ｻ繝ｭ繧ｰ":

    st.header("逶｣譟ｻ繝ｭ繧ｰ")

    tab1, tab2 = st.tabs(["謫堺ｽ懊Ο繧ｰ", "邨ｱ險・])

    with tab1:
        st.subheader("謫堺ｽ懊Ο繧ｰ荳隕ｧ")

        col1, col2 = st.columns(2)

        with col1:
            filter_username = st.text_input("繝ｦ繝ｼ繧ｶ繝ｼ蜷阪〒繝輔ぅ繝ｫ繧ｿ・育ｩｺ逋ｽ縺ｧ蜈ｨ縺ｦ・・, key="audit_username")

        with col2:
            filter_action = st.text_input("繧｢繧ｯ繧ｷ繝ｧ繝ｳ・育ｩｺ逋ｽ縺ｧ蜈ｨ縺ｦ・・, key="audit_action")

        if st.button("讀懃ｴ｢"):
            logs = AuditLogService.get_audit_logs(
                username=filter_username if filter_username else "",
                action=filter_action if filter_action else "",
                limit=200
            )

            if logs:
                st.dataframe(logs, use_container_width=True)
            else:
                st.info("繝ｭ繧ｰ縺後≠繧翫∪縺帙ｓ縲・)

    with tab2:
        st.subheader("謫堺ｽ懃ｵｱ險・)

        days = st.slider("驕主悉N譌･髢・, 1, 90, 30)

        col1, col2 = st.columns(2)

        with col1:
            st.subheader("謫堺ｽ懷挨髮・ｨ・)

            summary = AuditLogService.get_action_summary(days=days)

            if summary:
                st.dataframe(summary, use_container_width=True)

        with col2:
            st.subheader("繧ｨ繝ｩ繝ｼ邨ｱ險・)

            error_count = AuditLogService.get_error_count(days=days)

            st.metric("繧ｨ繝ｩ繝ｼ莉ｶ謨ｰ", error_count)

# ==========================
# 繝ｦ繝ｼ繧ｶ繝ｼ險ｭ螳夲ｼ・hase 5.1・・
# ==========================
elif menu == "笞呻ｸ・繝ｦ繝ｼ繧ｶ繝ｼ險ｭ螳・:

    st.header("繝ｦ繝ｼ繧ｶ繝ｼ險ｭ螳・)

    tab1, tab2 = st.tabs(["繝代せ繝ｯ繝ｼ繝牙､画峩", "繝励Ο繝輔ぅ繝ｼ繝ｫ邱ｨ髮・])

    with tab1:
        st.subheader("繝代せ繝ｯ繝ｼ繝牙､画峩")

        # 迴ｾ蝨ｨ縺ｮ繝ｦ繝ｼ繧ｶ繝ｼ諠・ｱ繧貞叙蠕・
        current_user = AuthService.get_user(st.session_state.username)

        if current_user:
            st.write(f"繝ｦ繝ｼ繧ｶ繝ｼ蜷・ **{current_user['username']}**")
            st.write(f"繝輔Ν繝阪・繝: {current_user['full_name']}")

        st.divider()

        old_password = st.text_input("迴ｾ蝨ｨ縺ｮ繝代せ繝ｯ繝ｼ繝・, type="password", key="old_pass")
        new_password = st.text_input("譁ｰ縺励＞繝代せ繝ｯ繝ｼ繝・, type="password", key="new_pass")
        new_password_confirm = st.text_input("譁ｰ縺励＞繝代せ繝ｯ繝ｼ繝会ｼ亥・蜈･蜉幢ｼ・, type="password", key="new_pass_confirm")

        if st.button("繝代せ繝ｯ繝ｼ繝峨ｒ螟画峩"):
            if not old_password:
                st.error("迴ｾ蝨ｨ縺ｮ繝代せ繝ｯ繝ｼ繝峨ｒ蜈･蜉帙＠縺ｦ縺上□縺輔＞")
            elif len(new_password) < 6:
                st.error("譁ｰ縺励＞繝代せ繝ｯ繝ｼ繝峨・6譁・ｭ嶺ｻ･荳翫〒縺・)
            elif new_password != new_password_confirm:
                st.error("譁ｰ縺励＞繝代せ繝ｯ繝ｼ繝峨′荳閾ｴ縺励∪縺帙ｓ")
            else:
                result = AuthService.change_password(
                    st.session_state.username,
                    old_password,
                    new_password
                )

                if result['success']:
                    st.success(result['message'])

                    # 逶｣譟ｻ繝ｭ繧ｰ繧定ｨ倬鹸
                    AuditLogService.log_action(
                        username=st.session_state.username,
                        action="CHANGE_PASSWORD",
                        table_name="users",
                        record_id=st.session_state.username,
                        detail="繝代せ繝ｯ繝ｼ繝峨ｒ螟画峩縺励∪縺励◆"
                    )

                else:
                    st.error(result['message'])

                    # 繧ｨ繝ｩ繝ｼ繝ｭ繧ｰ繧定ｨ倬鹸
                    AuditLogService.log_error(
                        username=st.session_state.username,
                        action="CHANGE_PASSWORD",
                        error_message=result['message']
                    )

    with tab2:
        st.subheader("繝励Ο繝輔ぅ繝ｼ繝ｫ邱ｨ髮・)

        # 迴ｾ蝨ｨ縺ｮ繝ｦ繝ｼ繧ｶ繝ｼ諠・ｱ繧貞叙蠕・
        current_user = AuthService.get_user(st.session_state.username)

        if current_user:
            full_name = st.text_input("繝輔Ν繝阪・繝", value=current_user['full_name'], key="edit_full_name")
            email = st.text_input("繝｡繝ｼ繝ｫ繧｢繝峨Ξ繧ｹ", value=current_user['email'] or "", key="edit_email")

            if st.button("繝励Ο繝輔ぅ繝ｼ繝ｫ繧呈峩譁ｰ"):
                result = AuthService.update_user_info(
                    st.session_state.username,
                    full_name=full_name,
                    email=email
                )

                if result['success']:
                    st.success(result['message'])

                    # 繧ｻ繝・す繝ｧ繝ｳ迥ｶ諷九ｒ譖ｴ譁ｰ
                    updated_user = AuthService.get_user(st.session_state.username)
                    st.session_state.user_info = updated_user

                    # 逶｣譟ｻ繝ｭ繧ｰ繧定ｨ倬鹸
                    AuditLogService.log_action(
                        username=st.session_state.username,
                        action="UPDATE_PROFILE",
                        table_name="users",
                        record_id=st.session_state.username,
                        detail=f"繝励Ο繝輔ぅ繝ｼ繝ｫ繧呈峩譁ｰ縺励∪縺励◆・医ヵ繝ｫ繝阪・繝: {full_name}・・
                    )

                    st.rerun()

                else:
                    st.error(result['message'])

        else:
            st.error("繝ｦ繝ｼ繧ｶ繝ｼ諠・ｱ繧貞叙蠕励〒縺阪∪縺帙ｓ")

else:  # 庁 縺吶∋縺ｦ縺ｮ繝｡繝九Η繝ｼ譚｡莉ｶ縺九ｉ螟悶ｌ縺滄圀縺ｮ繧ｻ繝ｼ繝輔ユ繧｣繧ｬ繝ｼ繝峨→縺励※譛荳矩Κ縺ｫ驟咲ｽｮ
    st.write("繝｡繝九Η繝ｼ繧帝∈謚槭＠縺ｦ縺上□縺輔＞縲・)

