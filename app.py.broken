elif menu == "繝槭せ繧ｿ邂｡逅・:
    st.header("繝槭せ繧ｿ邂｡逅・)

    categories = {
        "讓ｹ閼・: "materials",
        "濶ｲ": "colors",
        "蠖｢迥ｶ": "shapes",
        "闕ｷ蟋ｿ": "packages",
        "菫晉ｮ｡蝣ｴ謇": "locations",
        "蜿門ｼ募・": "customers",
    }

    selected_label = st.selectbox("繝槭せ繧ｿ遞ｮ蛻･", list(categories.keys()))
    selected_category = categories[selected_label]

    st.subheader(f"{selected_label} 縺ｮ霑ｽ蜉")

    new_name = st.text_input("霑ｽ蜉縺吶ｋ蜷咲ｧｰ")

    if st.button("霑ｽ蜉"):
        if not new_name:
            st.error("蜷咲ｧｰ繧貞・蜉帙＠縺ｦ縺上□縺輔＞縲・)
        else:
            insert_master_item(selected_category, new_name)
            st.success(f"{selected_label} 縺ｫ {new_name} 繧定ｿｽ蜉縺励∪縺励◆縲・)

    st.subheader(f"{selected_label} 荳隕ｧ")

    items = get_master_items_with_order(selected_category)

    if items:
        order_dict = {}

        for item in items:
            name = item["name"]
            current_order = int(item["sort_order"] or ((items.index(item) + 1) * 10))

            col1, col2, col3 = st.columns([4, 2, 2])

            with col1:
                st.write(name)

            with col2:
                order = st.number_input(
                    "陦ｨ遉ｺ鬆・,
                    value=current_order,
                    step=10,
                    key=f"{selected_category}_{name}_order"
                )

            order_dict[name] = order

            with col3:
                if st.button("辟｡蜉ｹ蛹・, key=f"delete_{selected_category}_{name}"):
                    deactivate_master_item(selected_category, name)
                    st.success(f"{name} 繧堤┌蜉ｹ蛹悶＠縺ｾ縺励◆縲・)

        if st.button("陦ｨ遉ｺ鬆・ｒ荳諡ｬ菫晏ｭ・):
            update_master_sort_orders(selected_category, order_dict)
            st.success("陦ｨ遉ｺ鬆・ｒ菫晏ｭ倥＠縺ｾ縺励◆縲ら判髱｢繧呈峩譁ｰ縺励※縺上□縺輔＞縲・)

        if len(set(order_dict.values())) != len(order_dict):
            st.error("陦ｨ遉ｺ鬆・′驥崎､・＠縺ｦ縺・∪縺吶・)

