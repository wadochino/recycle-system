        if r["迥ｶ諷・] in ["蜴滓侭蝨ｨ蠎ｫ", "邊臥募ｾ・■", "荳ｭ髢灘惠蠎ｫ", "陬ｽ蜩∝惠蠎ｫ"]
    ]

    if active_rows:
        customers = sorted(set(r["蜿門ｼ募・"] for r in active_rows if r["蜿門ｼ募・"]))
        locations_list = sorted(set(r["菫晉ｮ｡蝣ｴ謇"] for r in active_rows if r["菫晉ｮ｡蝣ｴ謇"]))
        statuses = sorted(set(r["迥ｶ諷・] for r in active_rows if r["迥ｶ諷・]))

        col1, col2, col3 = st.columns(3)

        with col1:
            selected_customer = st.selectbox("蜿門ｼ募・", ["縺吶∋縺ｦ"] + customers)

        with col2:
            selected_location = st.selectbox("菫晉ｮ｡蝣ｴ謇", ["縺吶∋縺ｦ"] + locations_list)

        with col3:
            selected_status = st.selectbox("迥ｶ諷・, ["縺吶∋縺ｦ"] + statuses)

        filtered = active_rows

        if selected_customer != "縺吶∋縺ｦ":
            filtered = [r for r in filtered if r["蜿門ｼ募・"] == selected_customer]

        if selected_location != "縺吶∋縺ｦ":
            filtered = [r for r in filtered if r["菫晉ｮ｡蝣ｴ謇"] == selected_location]

        if selected_status != "縺吶∋縺ｦ":
            filtered = [r for r in filtered if r["迥ｶ諷・] == selected_status]

        st.dataframe(filtered, use_container_width=True)

        total = sum(safe_int(r["驥埼㍼kg"]) for r in filtered)
        st.subheader("陦ｨ遉ｺ荳ｭ縺ｮ髮・ｨ・)
        st.write(f"蝨ｨ蠎ｫ蜊倅ｽ肴焚・嘴len(filtered)}")
        st.write(f"邱城㍾驥擾ｼ嘴total:,} kg")

        st.subheader("蜿門ｼ募・縺斐→縺ｮ蜷郁ｨ磯㍾驥・)
        summary = defaultdict(int)
        for r in active_rows:
            summary[r["蜿門ｼ募・"]] += safe_int(r["驥埼㍼kg"])

        st.dataframe(
            [{"蜿門ｼ募・": k, "蜷郁ｨ磯㍾驥縮g": f"{v:,}"} for k, v in summary.items()],
            use_container_width=True
        )

    else:
        st.write("迴ｾ蝨ｨ蠎ｫ縺後≠繧翫∪縺帙ｓ縲・)

# ==========================
# 蜉蟾･逋ｻ骭ｲ
# ==========================
elif menu == "蜉蟾･逋ｻ骭ｲ":
    st.header("蜉蟾･逋ｻ骭ｲ")

    rows = get_inventory_rows()

    from collections import Counter

    st.write("蜈ｨ蝨ｨ蠎ｫ莉ｶ謨ｰ", len(rows))
    st.write("迥ｶ諷句挨莉ｶ謨ｰ")
    st.write(Counter([r["迥ｶ諷・] for r in rows]))

    active_rows = [r for r in rows if r["迥ｶ諷・] not in ["蜉蟾･貂・, "蜃ｺ闕ｷ貂・]]

    if not active_rows:
        st.warning("蜉蟾･縺ｧ縺阪ｋ蝨ｨ蠎ｫ縺後≠繧翫∪縺帙ｓ縲・)
    else:
        options = [
            f'{r["蝨ｨ蠎ｫ蜊倅ｽ巧D"]} / {r["蜿門ｼ募・"]} / {r["讓ｹ閼・]} / {r["蠖｢迥ｶ"]} / {r["驥埼㍼kg"]}kg / {r["迥ｶ諷・]}'
            for r in active_rows
        ]

        selected_items = st.multiselect("蜉蟾･蟇ｾ雎｡", options)

        selected_rows = []
        for item in selected_items:
            selected_rows.append(active_rows[options.index(item)])

        if not selected_rows:
            st.warning("蜉蟾･縺吶ｋ蝨ｨ蠎ｫ繧帝∈謚槭＠縺ｦ縺上□縺輔＞縲・)
            st.stop()

        source = selected_rows[0]
        source_ids = [r["蝨ｨ蠎ｫ蜊倅ｽ巧D"] for r in selected_rows]
        source_weight = sum(safe_int(r["驥埼㍼kg"]) for r in selected_rows)

        st.subheader("蜉蟾･蜑肴ュ蝣ｱ")

        source_table = [
            {"鬆・岼": "蝨ｨ蠎ｫID", "蜀・ｮｹ": source["蝨ｨ蠎ｫ蜊倅ｽ巧D"]},
            {"鬆・岼": "蜿門ｼ募・", "蜀・ｮｹ": source["蜿門ｼ募・"]},
            {"鬆・岼": "讓ｹ閼・, "蜀・ｮｹ": source["讓ｹ閼・]},
            {"鬆・岼": "濶ｲ", "蜀・ｮｹ": source["濶ｲ"]},
            {"鬆・岼": "蠖｢迥ｶ", "蜀・ｮｹ": source["蠖｢迥ｶ"]},
            {"鬆・岼": "闕ｷ蟋ｿ", "蜀・ｮｹ": source["闕ｷ蟋ｿ"]},
            {"鬆・岼": "驥埼㍼kg", "蜀・ｮｹ": source["驥埼㍼kg"]},
            {"鬆・岼": "菫晉ｮ｡蝣ｴ謇", "蜀・ｮｹ": source["菫晉ｮ｡蝣ｴ謇"]},
            {"鬆・岼": "迥ｶ諷・, "蜀・ｮｹ": source["迥ｶ諷・]},
        ]

        st.write(f"謚募・謨ｰ・嘴len(selected_rows)}莉ｶ")
        st.write(f"謚募・蜷郁ｨ磯㍾驥擾ｼ嘴source_weight:,} kg")
        st.dataframe(selected_rows, use_container_width=True)

        st.table(source_table)

        st.subheader("蜉蟾･繝代ち繝ｼ繝ｳ")

        pattern = st.selectbox(
            "蜉蟾･繝代ち繝ｼ繝ｳ繧帝∈謚・,
            [
                "謇句虚縺ｧ驕ｸ縺ｶ",
                "莉募・縺・竊・陬ｽ蜩∝惠蠎ｫ",
                "莉募・縺・竊・邊臥募ｾ・■",
                "邊臥・竊・荳ｭ髢灘惠蠎ｫ",
                "邊臥・竊・陬ｽ蜩∝惠蠎ｫ",
                "繝励Ξ繧ｹ 竊・陬ｽ蜩∝惠蠎ｫ",
                "繝壹Ξ繝・ヨ蜉蟾･ 竊・陬ｽ蜩∝惠蠎ｫ",
            ]
        )

        process = "縺昴・莉・
        default_shape = shapes[0]
        default_status = "荳ｭ髢灘惠蠎ｫ"

        if pattern == "莉募・縺・竊・陬ｽ蜩∝惠蠎ｫ":
            process = "莉募・縺・
            default_shape = source["蠖｢迥ｶ"]
            default_status = "陬ｽ蜩∝惠蠎ｫ"

        elif pattern == "莉募・縺・竊・邊臥募ｾ・■":
            process = "莉募・縺・
            default_shape = source["蠖｢迥ｶ"]
            default_status = "邊臥募ｾ・■"

        elif pattern == "邊臥・竊・荳ｭ髢灘惠蠎ｫ":
            process = "邊臥・
            default_shape = "邊臥・
            default_status = "荳ｭ髢灘惠蠎ｫ"

        elif pattern == "邊臥・竊・陬ｽ蜩∝惠蠎ｫ":
            process = "邊臥・
            default_shape = "邊臥・
            default_status = "陬ｽ蜩∝惠蠎ｫ"

        elif pattern == "繝励Ξ繧ｹ 竊・陬ｽ蜩∝惠蠎ｫ":
            process = "繝励Ξ繧ｹ"
            default_shape = "繝励Ξ繧ｹ蜩・
            default_status = "陬ｽ蜩∝惠蠎ｫ"

        elif pattern == "繝壹Ξ繝・ヨ蜉蟾･ 竊・陬ｽ蜩∝惠蠎ｫ":
            process = "繝壹Ξ繝・ヨ蜉蟾･"
            default_shape = "繝壹Ξ繝・ヨ"
            default_status = "陬ｽ蜩∝惠蠎ｫ"

        if pattern == "謇句虚縺ｧ驕ｸ縺ｶ":
            process = st.selectbox("蟾･遞・, ["莉募・縺・, "遐ｴ遐・, "邊臥・, "繝励Ξ繧ｹ", "繝壹Ξ繝・ヨ蜉蟾･", "縺昴・莉・])
        else:
            st.write(f"蟾･遞具ｼ嘴process}")

        new_shape = st.selectbox(
            "蜉蟾･蠕後・蠖｢迥ｶ",
            shapes,
            index=shapes.index(default_shape) if default_shape in shapes else 0
        )

        new_package = st.selectbox("蜉蟾･蠕後・闕ｷ蟋ｿ", packages)

        new_location = st.text_input("蜉蟾･蠕後・菫晉ｮ｡蝣ｴ謇", value=source["菫晉ｮ｡蝣ｴ謇"])

        new_status = st.selectbox(
            "蜉蟾･蠕後・迥ｶ諷・,
            ["邊臥募ｾ・■", "荳ｭ髢灘惠蠎ｫ", "陬ｽ蜩∝惠蠎ｫ"],
            index=["邊臥募ｾ・■", "荳ｭ髢灘惠蠎ｫ", "陬ｽ蜩∝惠蠎ｫ"].index(default_status)
        )

        st.subheader("蜉蟾･蠕碁㍾驥丞・蜉幢ｼ域隼陦後〒蛹ｺ蛻・ｋ・・)

        output_text = st.text_area(
            "蜉蟾･蠕碁㍾驥上ｒ1陦後★縺､蜈･蜉帙＠縺ｦ縺上□縺輔＞",
            placeholder="萓・\n500\n700\n600",
            key="process_output_text"
        )

        output_weights = []

        if output_text:
            for line in output_text.split("\n"):
                if line.strip():
                    w = safe_int(line)  # 庁 縺薙％縺ｧ繧ょ・隗呈焚蟄励ｒ險ｱ螳ｹ
                    if w > 0:
                        output_weights.append(w)

        output_weight = sum(output_weights)

        st.write(f"蜉蟾･蠕悟区焚・嘴len(output_weights)}莉ｶ / 蜷郁ｨ・{output_weight:,} kg")

        source_weight = sum(safe_int(r["驥埼㍼kg"]) for r in selected_rows)
        loss_weight = source_weight - output_weight

        st.info(f"蜉蟾･蜑搾ｼ嘴source_weight:,} kg")
        st.info(f"蜉蟾･蠕鯉ｼ嘴output_weight:,} kg")
        st.info(f"繝ｭ繧ｹ・嘴loss_weight:,} kg")

        note = st.text_area("蛯呵・)

        if st.button("蜉蟾･逋ｻ骭ｲ"):
            if output_weight <= 0:
                st.error("蜉蟾･蠕碁㍾驥上ｒ蜈･蜉帙＠縺ｦ縺上□縺輔＞縲・)
            elif loss_weight < 0:
                st.error("蜉蟾･蠕碁㍾驥上′蜉蟾･蜑埼㍾驥上ｒ雜・∴縺ｦ縺・∪縺吶・)
            else:
                # ProcessingService 繧剃ｽｿ逕ｨ縺励※繝医Λ繝ｳ繧ｶ繧ｯ繧ｷ繝ｧ繝ｳ邂｡逅・
                result = ProcessingService.execute_processing(
                    selected_rows=selected_rows,
                    process=process,
                    new_shape=new_shape,
                    new_package=new_package,
                    new_location=new_location,
                    new_status=new_status,
                    output_weights=output_weights,
                    note=note,
                )

                if result['success']:
                    st.success(f"蜉蟾･逋ｻ骭ｲ螳御ｺ・ゅΟ繝・ヨID・嘴result['lot_id']} / 譁ｰID・嘴', '.join(result['new_ids'])}")
                else:
                    st.error(result['message'])

# ==========================
# 蜃ｺ闕ｷ逋ｻ骭ｲ
# ==========================
elif menu == "蜃ｺ闕ｷ逋ｻ骭ｲ":
    st.header("蜃ｺ闕ｷ逋ｻ骭ｲ")

    rows = get_inventory_rows()
    shippable_rows = [r for r in rows if r["迥ｶ諷・] == "陬ｽ蜩∝惠蠎ｫ"]

    if not shippable_rows:
        st.warning("蜃ｺ闕ｷ縺ｧ縺阪ｋ陬ｽ蜩∝惠蠎ｫ縺後≠繧翫∪縺帙ｓ縲・)
    else:
        options = [
            f'{r["蝨ｨ蠎ｫ蜊倅ｽ巧D"]} / {r["蜿門ｼ募・"]} / {r["讓ｹ閼・]} / {r["蠖｢迥ｶ"]} / {r["驥埼㍼kg"]}kg / {r["菫晉ｮ｡蝣ｴ謇"]}'
            for r in shippable_rows
        ]

        selected_items = st.multiselect("蜃ｺ闕ｷ縺吶ｋ蝨ｨ蠎ｫ繧帝∈謚・, options)

        ship_date = st.date_input("蜃ｺ闕ｷ譌･", value=date.today())
        destination = st.text_input("蜃ｺ闕ｷ蜈・)
        note = st.text_area("蛯呵・)

        selected_ids = []
        total_weight = 0

        for item in selected_items:
            r = shippable_rows[options.index(item)]
            selected_ids.append(r["蝨ｨ蠎ｫ蜊倅ｽ巧D"])
            total_weight += safe_int(r["驥埼㍼kg"])

        st.info(f"蜃ｺ闕ｷ蟇ｾ雎｡・嘴len(selected_ids)}莉ｶ / 蜷郁ｨ・{total_weight:,} kg")

        if st.button("蜃ｺ闕ｷ逋ｻ骭ｲ"):
            if not selected_ids:
                st.error("蜃ｺ闕ｷ縺吶ｋ蝨ｨ蠎ｫ繧帝∈謚槭＠縺ｦ縺上□縺輔＞縲・)
            elif not destination:
                st.error("蜃ｺ闕ｷ蜈医ｒ蜈･蜉帙＠縺ｦ縺上□縺輔＞縲・)
            else:
                # ShippingService 繧剃ｽｿ逕ｨ縺励※繝医Λ繝ｳ繧ｶ繧ｯ繧ｷ繝ｧ繝ｳ邂｡逅・
                result = ShippingService.register_shipping(
                    selected_ids=selected_ids,
                    ship_date=ship_date,
                    destination=destination,
                    note=note,
                )

                if result['success']:
                    st.success(f"{result['count']}莉ｶ繧貞・闕ｷ逋ｻ骭ｲ縺励∪縺励◆縲ょ粋險・{total_weight:,} kg")
                else:
                    st.error(result['message'])

