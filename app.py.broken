# ==========================
# 蝨ｨ蠎ｫ遘ｻ蜍・
# ==========================
elif menu == "蝨ｨ蠎ｫ遘ｻ蜍・:
    st.header("蝨ｨ蠎ｫ遘ｻ蜍包ｼ井ｸ諡ｬ遘ｻ蜍包ｼ・)

    rows = get_inventory_rows()
    active_rows = [r for r in rows if r["迥ｶ諷・] not in ["蜉蟾･貂・, "蜃ｺ闕ｷ貂・, "隱､逋ｻ骭ｲ", "蟒・｣・, "霑泌刀"]]

    if not active_rows:
        st.warning("遘ｻ蜍輔〒縺阪ｋ蝨ｨ蠎ｫ縺後≠繧翫∪縺帙ｓ縲・)
    else:
        dates = sorted(set(r["譌･莉・] for r in active_rows if r["譌･莉・]))
        customers = sorted(set(r["蜿門ｼ募・"] for r in active_rows if r["蜿門ｼ募・"]))

        col1, col2 = st.columns(2)

        with col1:
            selected_date = st.selectbox("蜈･闕ｷ譌･縺ｧ邨槭ｊ霎ｼ縺ｿ", ["縺吶∋縺ｦ"] + dates)

        with col2:
            selected_customer = st.selectbox("蜿門ｼ募・縺ｧ邨槭ｊ霎ｼ縺ｿ", ["縺吶∋縺ｦ"] + customers)

        filtered = active_rows

        if selected_date != "縺吶∋縺ｦ":
            filtered = [r for r in filtered if r["譌･莉・] == selected_date]

        if selected_customer != "縺吶∋縺ｦ":
            filtered = [r for r in filtered if r["蜿門ｼ募・"] == selected_customer]

        st.subheader("遘ｻ蜍募ｯｾ雎｡蛟呵｣・)
        st.write(f"蛟呵｣應ｻｶ謨ｰ・嘴len(filtered)}莉ｶ")

        if filtered:
            st.dataframe(filtered, use_container_width=True)

            options = [
                f'{r["蝨ｨ蠎ｫ蜊倅ｽ巧D"]} / {r["蜿門ｼ募・"]} / {r["讓ｹ閼・]} / {r["蠖｢迥ｶ"]} / {r["驥埼㍼kg"]}kg / {r["菫晉ｮ｡蝣ｴ謇"]}'
                for r in filtered
            ]

            selected_items = st.multiselect("遘ｻ蜍輔☆繧句惠蠎ｫ繧帝∈謚・, options)

            selected_ids = []
            total_weight = 0

            for item in selected_items:
                r = filtered[options.index(item)]
                selected_ids.append(r["蝨ｨ蠎ｫ蜊倅ｽ巧D"])
                total_weight += safe_int(r["驥埼㍼kg"])

            st.info(f"驕ｸ謚樔ｸｭ・嘴len(selected_ids)}莉ｶ / 蜷郁ｨ・{total_weight:,} kg")

            locations_list = [
                "蜃ｺ闕ｷ繝､繝ｼ繝・,
                "隨ｬ2蟾･蝣ｴ",
                "蟇悟｣ｫ莠区･ｭ謇",
                "蜈･螻ｱ轢ｬ蛟牙ｺｫ",
                "萓晉伐讖句牙ｺｫ"
            ]

            new_location = st.selectbox("遘ｻ蜍募・", locations_list)
            note = st.text_input("蛯呵・ｼ井ｻｻ諢擾ｼ・)

            if st.button("荳諡ｬ遘ｻ蜍募ｮ溯｡・):
                if not selected_ids:
                    st.error("遘ｻ蜍輔☆繧句惠蠎ｫ繧帝∈謚槭＠縺ｦ縺上□縺輔＞縲・)
                else:
                    for r in rows:
                        if r["蝨ｨ蠎ｫ蜊倅ｽ巧D"] in selected_ids:
                            old_location = r["菫晉ｮ｡蝣ｴ謇"]

                            update_inventory_location(
                                r["蝨ｨ蠎ｫ蜊倅ｽ巧D"],
                                new_location,
                                f"遘ｻ蜍・ {old_location} 竊・{new_location} / {note}"
                            )

                            insert_history(
                                str(date.today()),
                                r["蝨ｨ蠎ｫ蜊倅ｽ巧D"],
                                "蝨ｨ蠎ｫ遘ｻ蜍・,
                                f"{old_location} 竊・{new_location} / {note}",
                                r["驥埼㍼kg"]
                            )

                    st.success(f"{len(selected_ids)}莉ｶ繧・{new_location} 縺ｫ遘ｻ蜍輔＠縺ｾ縺励◆縲・)

# ==========================
# 迥ｶ諷句､画峩
# ==========================
elif menu == "迥ｶ諷句､画峩":
    st.header("迥ｶ諷句､画峩")

    rows = get_inventory_rows()

    target_rows = [r for r in rows if r["迥ｶ諷・] not in ["蜉蟾･貂・, "蜃ｺ闕ｷ貂・, "隱､逋ｻ骭ｲ", "蟒・｣・, "霑泌刀"]]

    if not target_rows:
        st.warning("迥ｶ諷句､画峩縺ｧ縺阪ｋ蝨ｨ蠎ｫ縺後≠繧翫∪縺帙ｓ縲・)
    else:
        options = [
            f'{r["蝨ｨ蠎ｫ蜊倅ｽ巧D"]} / {r["蜿門ｼ募・"]} / {r["讓ｹ閼・]} / {r["驥埼㍼kg"]}kg / {r["迥ｶ諷・]} / {r["菫晉ｮ｡蝣ｴ謇"]}'
            for r in target_rows
        ]

        selected = st.selectbox("迥ｶ諷句､画峩縺吶ｋ蝨ｨ蠎ｫ繧帝∈謚・, options)
        source = target_rows[options.index(selected)]

        st.subheader("迴ｾ蝨ｨ縺ｮ諠・ｱ")
        st.table([
            {"鬆・岼": "蝨ｨ蠎ｫID", "蜀・ｮｹ": source["蝨ｨ蠎ｫ蜊倅ｽ巧D"]},
            {"鬆・岼": "蜿門ｼ募・", "蜀・ｮｹ": source["蜿門ｼ募・"]},
            {"鬆・岼": "讓ｹ閼・, "蜀・ｮｹ": source["讓ｹ閼・]},
            {"鬆・岼": "驥埼㍼kg", "蜀・ｮｹ": source["驥埼㍼kg"]},
            {"鬆・岼": "迴ｾ蝨ｨ迥ｶ諷・, "蜀・ｮｹ": source["迥ｶ諷・]},
            {"鬆・岼": "菫晉ｮ｡蝣ｴ謇", "蜀・ｮｹ": source["菫晉ｮ｡蝣ｴ謇"]},
        ])

        new_status = st.selectbox("螟画峩蠕後・迥ｶ諷・, ["隱､逋ｻ骭ｲ", "蟒・｣・, "霑泌刀"])
        note = st.text_area("逅・罰繝ｻ蛯呵・)

        if st.button("迥ｶ諷句､画峩螳溯｡・):
            if not note:
                st.error("逅・罰繝ｻ蛯呵・ｒ蜈･蜉帙＠縺ｦ縺上□縺輔＞縲・)
            else:
                old_status = source["迥ｶ諷・]

                update_inventory_status(
                    source["蝨ｨ蠎ｫ蜊倅ｽ巧D"],
                    new_status,
                    f"迥ｶ諷句､画峩: {old_status} 竊・{new_status} / {note}"
                )

                insert_history(
                    str(date.today()),
                    source["蝨ｨ蠎ｫ蜊倅ｽ巧D"],
                    "迥ｶ諷句､画峩",
                    f"{old_status} 竊・{new_status} / {note}",
                    source["驥埼㍼kg"]
                )

                st.success(f"{source['蝨ｨ蠎ｫ蜊倅ｽ巧D']} 繧・{new_status} 縺ｫ螟画峩縺励∪縺励◆縲・)

# ==========================
# 繝ｩ繝吶Ν蜊ｰ蛻ｷ・亥ｰら畑・・
# ==========================
elif menu == "繝ｩ繝吶Ν蜊ｰ蛻ｷ":
    st.header("繝ｩ繝吶Ν蜊ｰ蛻ｷ・亥ｰら畑・・)

