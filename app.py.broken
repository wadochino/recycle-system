elif menu == "繝代ち繝ｼ繝ｳ逋ｻ骭ｲ":
    st.header("繝代ち繝ｼ繝ｳ逋ｻ骭ｲ")

    customer = st.text_input("蜿門ｼ募・繧ｳ繝ｼ繝・)

