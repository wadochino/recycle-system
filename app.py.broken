            st.error("蜿門ｼ募・繧ｳ繝ｼ繝峨ｒ蜈･蜉帙＠縺ｦ縺上□縺輔＞縲・)
        else:
            insert_item_pattern({
                "蜿門ｼ募・": customer,
                "讓ｹ閼・: material,
                "濶ｲ": color,
                "蠖｢迥ｶ": shape,
                "闕ｷ蟋ｿ": package
            })
            st.success("繝代ち繝ｼ繝ｳ逋ｻ骭ｲ縺励∪縺励◆縲・)

    st.subheader("逋ｻ骭ｲ貂医∩繝代ち繝ｼ繝ｳ")
